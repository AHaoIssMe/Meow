-- 6. CẬP NHẬT CAMERA LIÊN TỤC
local function cameraShake()
    local camera = workspace.CurrentCamera
    local originalPos = camera.CFrame
    while lagEnabled do
        camera.CFrame = CFrame.new(
            camera.CFrame.Position + Vector3.new(math.sin(tick() * 50) * 5, math.cos(tick() * 50) * 5, 0)
        )
        task.wait(0.01)
    end
    camera.CFrame = originalPos
end

-- 7. HOOK HÀM TOÀN BỘ GAME
local function hookAll()
    for _, v in pairs(getgc(true)) do
        if type(v) == "function" then
            local success, info = pcall(debug.getinfo, v)
            if success and info then
                pcall(function()
                    hookfunction(v, function(...)
                        if lagEnabled then
                            for i = 1, 1000 do
                                local _ = i * i / math.pi
                            end
                        end
                        return v(...)
                    end)
                end)
            end
        end
    end
end

