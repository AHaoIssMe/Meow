-- HÀM TẠO NÚT NGƯỜI CHƠI
local function createPlayerButton(player)
    local btn = Instance.new("TextButton", PlayerList)
    btn.Size = UDim2.new(1, -5, 0, 25)
    btn.BackgroundColor3 = player == LocalPlayer and Color3.fromRGB(80, 80, 100) or Color3.fromRGB(60, 60, 80)
    btn.BorderSizePixel = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
    
    local nameLabel = Instance.new("TextLabel", btn)
    nameLabel.Size = UDim2.new(0.7, 0, 1, 0)
    nameLabel.Position = UDim2.new(0, 5, 0, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.Name
    nameLabel.Font = Enum.Font.Gotham
    nameLabel.TextSize = 12
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    local status = Instance.new("TextLabel", btn)
    status.Size = UDim2.new(0.2, 0, 1, 0)
    status.Position = UDim2.new(0.8, 0, 0, 0)
    status.BackgroundTransparency = 1
    status.Text = getgenv().FrozenPlayers[player.Name] and "❄️" or ""
    status.Font = Enum.Font.Gotham
    status.TextSize = 14
    status.TextColor3 = Color3.fromRGB(0, 200, 255)
    
    btn.MouseButton1Click:Connect(function()
        SearchBox.Text = player.Name
    end)
    
    return btn
end

-- CẬP NHẬT DANH SÁCH
local function updatePlayerList()
    for _, child in pairs(PlayerList:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    for _, player in pairs(Players:GetPlayers()) do
        createPlayerButton(player)
    end
end

