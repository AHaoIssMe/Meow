------------------------------------------------
-- HÀM FREEZE/UNFREEZE
------------------------------------------------

local function freezePlayer(targetPlayer)
    local player = Players:FindFirstChild(targetPlayer) or Players:FindFirstChild(tostring(targetPlayer))
    if not player then return false end
    
    local char = player.Character
    if not char then return false end
    
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") and not part.Anchored then
            part.Anchored = true
        end
    end
    
    getgenv().FrozenPlayers[player.Name] = true
    return true
end

local function unfreezePlayer(targetPlayer)
    local player = Players:FindFirstChild(targetPlayer) or Players:FindFirstChild(tostring(targetPlayer))
    if not player then return false end
    
    local char = player.Character
    if not char then return false end
    
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Anchored then
            part.Anchored = false
        end
    end
    
    getgenv().FrozenPlayers[player.Name] = nil
    return true
end

