AddToggle(2, {
    Name = " Super Attack (Beta,Lag)",
    Callback = function(state)
        getgenv().TotalAttackEnabled = state
        
        if state then
            print("🟢 Auto Attack TỔNG HỢP BẬT")
            
            -- ========== SCRIPT 1: FAST ATTACK (GIỮ NGUYÊN) ==========
            local RS = game:GetService("ReplicatedStorage")
            local Players = game:GetService("Players")
            local plr = Players.LocalPlayer
            
            local Net = require(RS.Modules.Net)
            local Combat = require(RS.Modules.CombatUtil)
            local hit = Net:RemoteEvent("RegisterHit", true)
            local atk = RS.Modules.Net["RE/RegisterAttack"]
            
            local last = 0
            local range = 100
            local hitRate = 0.1
            local combo = 2
            
            local fastConnection = game:GetService("RunService").Heartbeat:Connect(function()
                if not getgenv().TotalAttackEnabled then return end
                
                local char = plr.Character
                if not char then return end
                
                local root = char:FindFirstChild("HumanoidRootPart")
                local tool = char:FindFirstChildOfClass("Tool")
                
                if not (root and tool) then return end
                
                local now = tick()
                if now - last < hitRate then return end
                last = now
                
                local weapon = Combat:GetWeaponName(tool)
                local id = tostring(plr.UserId):sub(2,4)
                local fired = false
                
                for _, mob in ipairs(workspace.Enemies:GetChildren()) do
                    local hrp = mob:FindFirstChild("HumanoidRootPart")
                    local hum = mob:FindFirstChild("Humanoid")
                    
                    if hrp and hum and hum.Health > 0 then
                        if (hrp.Position - root.Position).Magnitude <= range then
                            if not fired then
                                atk:FireServer()
                                fired = true
                            end
                            for i = 1, combo do
                                hit:FireServer(hrp, {{mob, hrp}}, nil, nil, id)
                            end
                            Combat:ApplyDamageHighlight(mob, char, weapon, hrp)
                        end
                    end
                end
            end)
            
            -- ========== SCRIPT 2: AUTO ATTACK NHỎ (GIỮ NGUYÊN) ==========
            local p = game.Players.LocalPlayer
            local rs = game.ReplicatedStorage
            local Net2 = rs.Modules.Net
            local RH, RA = Net2["RE/RegisterHit"], Net2["RE/RegisterAttack"]
            
            local SendHit
            pcall(function()
                SendHit = getsenv(p.PlayerScripts:WaitForChildOfClass("LocalScript"))._G.SendHitsToServer
            end)
            
            local R = 999
            local Parts = {"Head", "HumanoidRootPart", "LeftHand", "RightHand", "LeftLowerArm", "RightLowerArm"}
            
            local function ngu(v)
                local h = v:FindFirstChild("Humanoid")
                local r = v:FindFirstChild("HumanoidRootPart")
                return h and r and h.Health > 0
            end
            
            local function trieu()
                local t, c = {}, p.Character
                if not c then return t end
                local hrp = c.HumanoidRootPart
                
                for _, v in pairs(workspace.Enemies:GetChildren()) do
                    if ngu(v) and (v.HumanoidRootPart.Position - hrp.Position).Magnitude <= R then
                        t[#t + 1] = v
                    end
                end
                for _, v in pairs(workspace.Characters:GetChildren()) do
                    if v ~= c and ngu(v) and (v.HumanoidRootPart.Position - hrp.Position).Magnitude <= R then
                        t[#t + 1] = v
                    end
                end
                return t
            end
            
            local function hh(v)
                return v:FindFirstChild(Parts[math.random(#Parts)]) or v.HumanoidRootPart
            end
            
            local autoConnection = game:GetService("RunService").Heartbeat:Connect(function()
                if not getgenv().TotalAttackEnabled then return end
                
                local c = p.Character
                if not c then return end
                
                local tg = trieu()
                if #tg == 0 then return end
                
                local a = {nil, {}}
                for _, v in pairs(tg) do
                    local pr = hh(v)
                    a[1] = a[1] or pr
                    a[2][#a[2] + 1] = {v, pr}
                end
                
                RA:FireServer(0)
                if SendHit then
                    SendHit(unpack(a))
                else
                    RH:FireServer(unpack(a))
                end
            end)
            
            -- Lưu connections
            getgenv()._attackConnections = {fast = fastConnection, auto = autoConnection}
            
        else
            print("🔴 Auto Attack TỔNG HỢP TẮT")
            
            -- TẮT CẢ 2 SCRIPT
            if getgenv()._attackConnections then
                if getgenv()._attackConnections.fast then
                    getgenv()._attackConnections.fast:Disconnect()
                end
                if getgenv()._attackConnections.auto then
                    getgenv()._attackConnections.auto:Disconnect()
                end
                getgenv()._attackConnections = nil
            end
            
            -- RESET CÁC BIẾN ĐỂ ĐẢM BẢO TẮT HẲN
            getgenv().TotalAttackEnabled = false
        end
    end
})

AddToggle(1, {
    Name = "Instant Prompts (Bỏ qua nút F)",
    Callback = function(state)
        local ProximityPromptService = game:GetService("ProximityPromptService")
        local Prompts = {}
        local ppsLoop1 = nil
        local ppsLoop2 = nil
        
        if state then
            -- BẬT INSTANT PROMPTS
            ppsLoop1 = ProximityPromptService.PromptShown:Connect(function(prompt)
                if Prompts[prompt] then return end
                Prompts[prompt] = prompt.HoldDuration
                prompt.HoldDuration = 0
            end)
            
            ppsLoop2 = ProximityPromptService.PromptHidden:Connect(function(prompt)
                if not Prompts[prompt] then return end
                prompt.HoldDuration = Prompts[prompt]
                Prompts[prompt] = nil
            end)
            
            -- LƯU LẠI ĐỂ TẮT SAU
            getgenv()._instantPromptsLoop1 = ppsLoop1
            getgenv()._instantPromptsLoop2 = ppsLoop2
            
            print("✅ Instant Prompts: BẬT")
        else
            -- TẮT INSTANT PROMPTS
            if getgenv()._instantPromptsLoop1 then
                getgenv()._instantPromptsLoop1:Disconnect()
                getgenv()._instantPromptsLoop1 = nil
            end
            if getgenv()._instantPromptsLoop2 then
                getgenv()._instantPromptsLoop2:Disconnect()
                getgenv()._instantPromptsLoop2 = nil
            end
            
            -- KHÔI PHỤC TẤT CẢ PROMPT CÒN SÓT
            for prompt, originalDuration in pairs(Prompts) do
                if prompt then
                    prompt.HoldDuration = originalDuration
                end
            end
            table.clear(Prompts)
            
            print("❌ Instant Prompts: TẮT")
        end
    end
})

