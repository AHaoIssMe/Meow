    Callback = function(state)
        getgenv().AutoJumpEnabled = state
        
        if state then
            -- BẬT AUTO JUMP
            print("🟢 Auto Jump BẬT")
            
            -- NGẮT KẾT NỐI CŨ NẾU CÓ
            if autoJumpConnection then
                autoJumpConnection:Disconnect()
                autoJumpConnection = nil
            end
            
            -- TẠO KẾT NỐI MỚI
            autoJumpConnection = game:GetService("RunService").Heartbeat:Connect(function()
                if not getgenv().AutoJumpEnabled then return end
                
                local player = game.Players.LocalPlayer
                local char = player.Character
                if not char then return end
                
                local humanoid = char:FindFirstChild("Humanoid")
                if not humanoid then return end
                
                -- KIỂM TRA NẾU ĐANG ĐỨNG TRÊN MẶT ĐẤT
                if humanoid.FloorMaterial ~= Enum.Material.Air then
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end)
            
        else
            -- TẮT AUTO JUMP
            print("🔴 Auto Jump TẮT")
            if autoJumpConnection then
                autoJumpConnection:Disconnect()
                autoJumpConnection = nil
            end
        end
    end
})

-- NÚT AUTO ATTACK
AddToggle(4, {
    Name = "Auto Attack",
    Callback = function(state)
        getgenv().AutoAttackEnabled = state
        
        if state then
            -- BẬT AUTO ATTACK
            local plr = game:GetService("Players").LocalPlayer
            local rs = game:GetService("ReplicatedStorage")
            local remote = rs:WaitForChild("Events"):WaitForChild("GameRemoteFunction")
            local range = 99

            local function v(x,y,z)
                return Vector3.new(x,y,z)
            end

            getgenv().AutoAttackLoop = task.spawn(function()
                while getgenv().AutoAttackEnabled do
                    local char = plr.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    local tool = char and char:FindFirstChildOfClass("Tool")
                    
                    if hrp and tool then
                        local list = {}
                        
                        for _,p in pairs(game.Players:GetPlayers()) do
                            if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                                local ehrp = p.Character.HumanoidRootPart
                                local dist = (ehrp.Position - hrp.Position).Magnitude
                                
                                if dist <= range then
                                    table.insert(list,{
                                        knockback = 146.25,
                                        isClosestEnemy = (#list == 0),
                                        origin = v(hrp.Position.X,hrp.Position.Y,hrp.Position.Z),
                                        enemyModel = p.Character,
                                        distance = dist,
                                        direction = v(
                                            (ehrp.Position - hrp.Position).Unit.X,
                                            (ehrp.Position - hrp.Position).Unit.Y,
                                            (ehrp.Position - hrp.Position).Unit.Z
                                        )
                                    })
                                end
                            end
                        end
                        
                        if #list > 0 then
                            remote:InvokeServer(
                                "AttemptWeaponHit",
                                {
                                    damage = 99999999999999999999999999,
                                    attackCooldown = 0.025,
                                    cycleIndex = 4,
                                    tool = tool,
                                    hitboxSize = v(10,14,13)
                                },
                                list
                            )
                        end
                    end
                    
                    task.wait(0.0000000000000001)
                end
            end)
            
        else
            -- TẮT AUTO ATTACK
            if getgenv().AutoAttackLoop then
                task.cancel(getgenv().AutoAttackLoop)
                getgenv().AutoAttackLoop = nil
            end
        end
    end
})

