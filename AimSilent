local function getTargetPosition()
    if not getgenv().SilentAimEnabled then return nil end
    
    local char = player.Character
    if not char then return nil end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    
    local closestPlayer = nil
    local closestDist = math.huge
    
    for _, pl in pairs(Players:GetPlayers()) do
        if pl ~= player and pl.Character then
            local hrp = pl.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (hrp.Position - root.Position).Magnitude
                if dist < closestDist and dist <= 1000 then
                    closestDist = dist
                    closestPlayer = hrp
                end
            end
        end
    end
    
    if closestPlayer then
        return closestPlayer.Position
    end
    
    local enemiesFolder = workspace:FindFirstChild("Enemies")
    if enemiesFolder then
        local closestNPC = nil
        local closestNPCDist = math.huge
        
        for _, npc in pairs(enemiesFolder:GetChildren()) do
            if npc:IsA("Model") then
                local hrp = npc:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dist = (hrp.Position - root.Position).Magnitude
                    if dist < closestNPCDist and dist <= 1000 then
                        closestNPCDist = dist
                        closestNPC = hrp
                    end
                end
            end
        end
        
        if closestNPC then
            return closestNPC.Position
        end
    end
    
    return nil
end

local function setupHook()
    local ok, hookMeta = pcall(getrawmetatable, game)
    if ok and hookMeta then
        setreadonly(hookMeta, false)
        local oldHook
        oldHook = hookmetamethod(game, "__namecall", function(self, ...)
            local method = (getnamecallmethod and getnamecallmethod():lower()) or ""
            local args = {...}
            
            if getgenv().SilentAimEnabled and tostring(self) == "RemoteEvent" and method == "fireserver" then
                local targetPos = getTargetPosition()
                if targetPos and type(args[1]) == "Vector3" then
                    return oldHook(self, targetPos, args[2], args[3])
                end
            end
            
            return oldHook(self, ...)
        end)
        setreadonly(hookMeta, true)
    end
end

setupHook()

