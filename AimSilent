local function updateButton()
    if getgenv().SilentAimEnabled then
        Button.BackgroundColor3 = Color3.fromRGB(80, 255, 80)
        LED.BackgroundColor3 = Color3.fromRGB(50, 255, 50)
        Stroke.Color = Color3.fromRGB(80, 255, 80)
    else
        Button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
        LED.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        Stroke.Color = Color3.fromRGB(255, 255, 255)
    end
end

