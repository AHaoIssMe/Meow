local DevText = Instance.new("TextLabel", ScreenGui)
DevText.Size = UDim2.new(0, 110, 0, 15)
DevText.Position = UDim2.new(0.5, -55, 0.5, -38)
DevText.Text = "AnhhHaoo"
DevText.Font = Enum.Font.Gotham
DevText.TextSize = 10
DevText.TextColor3 = Color3.fromRGB(200, 200, 200)
DevText.BackgroundTransparency = 1

local function updateButton()
    if getgenv().FastAttackEnabled then
        Button.BackgroundColor3 = Color3.fromRGB(80, 255, 80)  
        LED.BackgroundColor3 = Color3.fromRGB(50, 255, 50)
        Stroke.Color = Color3.fromRGB(80, 255, 80)
    else
        Button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)  
        LED.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        Stroke.Color = Color3.fromRGB(255, 255, 255)
    end
end

Button.MouseButton1Click:Connect(function()
    getgenv().FastAttackEnabled = not getgenv().FastAttackEnabled
    updateButton()
    
    Button.TextTransparency = 0.5
    task.wait(0.1)
    Button.TextTransparency = 0
end)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.F then
        getgenv().FastAttackEnabled = not getgenv().FastAttackEnabled
        updateButton()
    end
end)

Button.MouseEnter:Connect(function()
    TweenService:Create(Button, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
end)
Button.MouseLeave:Connect(function()
    TweenService:Create(Button, TweenInfo.new(0.2), {BackgroundTransparency = 0.1}):Play()
end)

updateButton()

task.spawn(function()
    local RS = game:GetService("ReplicatedStorage")
    local plr = LocalPlayer
    
    local Net, Combat
    pcall(function()
        Net = require(RS.Modules.Net)
        Combat = require(RS.Modules.CombatUtil)
    end)
    
    if not Net or not Combat then
        warn("Không thể load module, thử cách khác...")
        return
    end
    
    local hit = Net:RemoteEvent("RegisterHit", true)
    local atk = RS.Modules.Net["RE/RegisterAttack"]
    
    local last = 0
    local range = 100
    local hitRate = 0.1
    local combo = 2
    
    while true do
        task.wait()
        
        if not getgenv().FastAttackEnabled then
            task.wait(0.5)
            continue
        end
        
        local char = plr.Character
        if not char then continue end
        
        local root = char:FindFirstChild("HumanoidRootPart")
        local tool = char:FindFirstChildOfClass("Tool")
        
        if not (root and tool) then continue end
        
        local now = tick()
        if now - last < hitRate then continue end
        last = now
        
        local weapon = Combat:GetWeaponName(tool)
        local id = tostring(plr.UserId):sub(2,4)
        local fired = false
        
        for _, mob in ipairs(workspace.Enemies:GetChildren()) do
            local hrp = mob:FindFirstChild("HumanoidRootPart")
            local hum = mob:FindFirstChild("Humanoid")
            
            if hrp and hum and hum.Health > 0 then
                if (hrp.Position - root.Position).Magnitude <= range then
                    if not fired then
                        atk:FireServer()
                        fired = true
                    end
                    for i = 1, combo do
                        hit:FireServer(hrp, {{mob, hrp}}, nil, nil, id)
                    end
                    Combat:ApplyDamageHighlight(mob, char, weapon, hrp)
                end
            end
        end
    end
end)